# Copy to ".env" — Supabase: Project Settings → API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: bare usernames map to name@<domain> (default example.com). Use your own domain in production.
# VITE_LOGIN_EMAIL_DOMAIN=yourdomain.com

# Optional: public site URL for OAuth / redirects if you add them later.
# VITE_SITE_URL=https://your-app.netlify.app
